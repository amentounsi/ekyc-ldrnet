*.tsbuildinfo

# Android build artifacts (native source code IS committed)
android/.gradle/
android/build/
android/app/build/
android/.cxx/
android/local.properties
android/**/*.orig

# OpenCV Android SDK — too large for git (776 MB).
# Download separately: https://github.com/opencv/opencv/releases/tag/4.10.0
# Extract to: android/app/src/main/cpp/OpenCV-android-sdk/
android/app/src/main/cpp/OpenCV-android-sdk/

# Debug images generated during testing
*_debug.png
*_debug_*.png
